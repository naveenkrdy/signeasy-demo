# Signeasy OAuth client credentials (from developer portal: Apps -> Sandbox -> Authentication)
SIGNEASY_CLIENT_ID=your_client_id_here
SIGNEASY_CLIENT_SECRET=your_client_secret_here

# Defaults (rarely changed). Set SIGNEASY_BASE_URL=https://api.signeasy.com/v3 for live too.
SIGNEASY_AUTH_URL=https://auth.signeasy.com/oauth/token
SIGNEASY_AUDIENCE=https://api-ext.signeasy.com/
SIGNEASY_BASE_URL=https://api.signeasy.com/v3

# Optional: space-separated OAuth scopes to request from the token endpoint.
# Leave blank to use whatever the app is configured with in the Signeasy developer portal.
# Full set for this demo: original:create rs:create rs:read rs:update signed:read
# SIGNEASY_SCOPE=original:create rs:create rs:read rs:update signed:read

# Backend port
PORT=3001
